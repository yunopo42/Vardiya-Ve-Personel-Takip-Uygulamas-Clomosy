  pnlRaporlar = yonetici.AddNewProPanel(vertScrollBox, 'pnlRaporlar');
  pnlRaporlar.Align = alTop;
  pnlRaporlar.Height = 145;
  pnlRaporlar.Margins.Left = 16;
  pnlRaporlar.Margins.Right = 16;
  pnlRaporlar.clProSettings.BackgroundColor = clAlphaColor.clHexToColor('#F8FAFC');
  pnlRaporlar.SetclProSettings(pnlRaporlar.clProSettings);

  btnRaporGirisCikis = yonetici.AddNewProButton(pnlRaporlar, 'btnRaporGirisCikis', 'Giriş/Çıkış Raporu');
  btnRaporGirisCikis.Align = alTop;
  btnRaporGirisCikis.Height = 40;
  StilButton(btnRaporGirisCikis, '#EEF2FF', '#3730A3');
  yonetici.AddNewEvent(btnRaporGirisCikis, tbeOnClick, 'GoToGirisCikisRaporu');

  btnPinRaporu = yonetici.AddNewProButton(pnlRaporlar, 'btnPinRaporu', 'PIN Geçmişi');
  btnPinRaporu.Align = alTop;
  btnPinRaporu.Height = 40;
  btnPinRaporu.Margins.Top = 8;
  StilButton(btnPinRaporu, '#ECFDF5', '#047857');
  yonetici.AddNewEvent(btnPinRaporu, tbeOnClick, 'GoToPinRaporu');

  btnPersonelYonetim = yonetici.AddNewProButton(pnlRaporlar, 'btnPersonelYonetim', 'Personel Yönetimi');
  btnPersonelYonetim.Align = alTop;
  btnPersonelYonetim.Height = 40;
  btnPersonelYonetim.Margins.Top = 8;
  StilButton(btnPersonelYonetim, '#FFFBEB', '#92400E');
  yonetici.AddNewEvent(btnPersonelYonetim, tbeOnClick, 'GoToPersonelYonetim');

  lblOzetBaslik = yonetici.AddNewProLabel(vertScrollBox, 'lblOzetBaslik', 'Vardiya Özeti');
  lblOzetBaslik.Align = alTop;
  lblOzetBaslik.Height = 30;
  lblOzetBaslik.Margins.Left = 16;
  lblOzetBaslik.Margins.Top = 20;
  lblOzetBaslik.clProSettings.FontColor = clAlphaColor.clHexToColor('#0F172A');
  lblOzetBaslik.clProSettings.FontSize = 15;
  lblOzetBaslik.clProSettings.TextSettings.Font.Style = [fsBold];
  lblOzetBaslik.SetclProSettings(lblOzetBaslik.clProSettings);

  kart1 = KartOlustur(vertScrollBox, 'k1', 'BUGÜN GİRİŞ YAPAN', '0', '#3B82F6', 'PIN ile giriş yapan personel sayısı');
  kart2 = KartOlustur(vertScrollBox, 'k2', 'BUGÜN İZİNLİ', '0', '#F59E0B', 'Onaylı izinde olan personel sayısı');
  kart3 = KartOlustur(vertScrollBox, 'k3', 'EKSİK PERSONEL', '0', '#EF4444', 'Giriş yapmayan ve izinli olmayan personel');

  yonetici.AddNewProPanel(vertScrollBox, 'pnlBottomSpace').Align = alTop;

  DashboardSayilariYukle;

  yonetici.Run;
}


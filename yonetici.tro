var
  yonetici: TCLForm;

  RestClient: TclRest;
  SUPABASE_URL: String;
  SUPABASE_KEY: String;

  pnlTopBar, pnlBottomNav, pnlWelcome, pnlAktifVardiya, pnlHizliIslemler, pnlPinGiris, pnlRaporlar: TclProPanel;
  imgLogoTop, imgAvatarTop: TclProImage;
  lblBrand, lblHosGeldin, lblVardiyaBilgi: TclProLabel;
  lblVardiyaSaat, lblVardiyaBolum: TclProLabel;
  lblHizliIslemBaslik, lblRaporBaslik, lblOzetBaslik, lblPinGirisBaslik: TclProLabel;

  btnKontrolPaneli, btnProfil: TclProButton;
  btnIzinOnay, btnVardiyaAta, btnYenile: TclProButton;
  btnRaporGirisCikis, btnPinRaporu, btnPersonelYonetim: TclProButton;
  btnPinOnayla: TclProButton;
  edtPersonelPin: TClEdit;

  vertScrollBox: TClVertScrollBox;

  kart1, kart2, kart3: TclProPanel;
  lblK1Rakam, lblK2Rakam, lblK3Rakam: TclProLabel;


void SupabaseAyarla
{
  SUPABASE_URL = ''; // Supabase URL removed for GitHub publishing.
  SUPABASE_KEY = ''; // Supabase anon key removed for GitHub publishing.
}


function SupabaseTextTemizle(metin: String): String;
var
  sonuc: String;
{
  sonuc = metin;

  if (sonuc == '""')
  {
    Result = '0';
    exit;
  }

  if (Length(sonuc) > 0)
  {
    if (Copy(sonuc, 1, 1) == '"')
      sonuc = Copy(sonuc, 2, Length(sonuc));
  }

  if (Length(sonuc) > 0)
  {
    if (Copy(sonuc, Length(sonuc), 1) == '"')
      sonuc = Copy(sonuc, 1, Length(sonuc) - 1);
  }

  if (sonuc == '')
    sonuc = '0';

  if (sonuc == 'null')
    sonuc = '0';

  Result = sonuc;
}


function RpcText(rpcName: String): String;
var
  url, response: String;
{
  try
    url = SUPABASE_URL + '/rpc/' + rpcName;

    RestClient = TclRest.Create;
    RestClient.BaseURL = url;
    RestClient.Accept = 'application/json';
    RestClient.ContentType = 'application/json';
    RestClient.Method = rmPOST;
    RestClient.AddHeader('apikey', SUPABASE_KEY);
    RestClient.AddHeader('Authorization', 'Bearer ' + SUPABASE_KEY);
    RestClient.Body = '{}';
    RestClient.Execute;

    response = SupabaseTextTemizle(RestClient.Response);
    Result = response;

  except
    Result = '0';
  }
}


void DashboardSayilariYukle
var
  gelenSayisi, toplamSayisi, izinliSayisi, eksikSayisi, bekleyenIzinSayisi: String;
{
  try
    gelenSayisi = RpcText('count_today_attendance');
    toplamSayisi = RpcText('count_total_users');
    izinliSayisi = RpcText('count_today_on_leave');
    eksikSayisi = RpcText('count_missing_users');
    bekleyenIzinSayisi = RpcText('count_pending_leave_requests');

    lblK1Rakam.Text = gelenSayisi;
    lblK2Rakam.Text = izinliSayisi;
    lblK3Rakam.Text = eksikSayisi;

    lblVardiyaBolum.Text = 'Gelen: ' + gelenSayisi
                          + ' | İzinli: ' + izinliSayisi
                          + ' | Eksik: ' + eksikSayisi
                          + ' | Toplam: ' + toplamSayisi;

    if (bekleyenIzinSayisi == '0')
      btnIzinOnay.Text = 'İzin'
    else
      btnIzinOnay.Text = 'İzin (' + bekleyenIzinSayisi + ')';

    lblK1Rakam.SetclProSettings(lblK1Rakam.clProSettings);
    lblK2Rakam.SetclProSettings(lblK2Rakam.clProSettings);
    lblK3Rakam.SetclProSettings(lblK3Rakam.clProSettings);
    lblVardiyaBolum.SetclProSettings(lblVardiyaBolum.clProSettings);
    btnIzinOnay.SetclProSettings(btnIzinOnay.clProSettings);

  except
    ShowMessage('Dashboard veri hatası: ' + LastExceptionMessage);
  }
}


void PinIleGirisCikis
var
  pinKod, url, body, response: String;
{
  pinKod = edtPersonelPin.Text;

  if (pinKod == '')
  {
    ShowMessage('Lütfen personel PIN kodunu giriniz.');
    exit;
  }

  url = SUPABASE_URL + '/rpc/handle_pin_attendance';
  body = '{"p_pin_code":"' + pinKod + '"}';

  try
    RestClient = TclRest.Create;
    RestClient.BaseURL = url;
    RestClient.Accept = 'application/json';
    RestClient.ContentType = 'application/json';
    RestClient.Method = rmPOST;
    RestClient.AddHeader('apikey', SUPABASE_KEY);
    RestClient.AddHeader('Authorization', 'Bearer ' + SUPABASE_KEY);
    RestClient.Body = body;
    RestClient.Execute;

    response = SupabaseTextTemizle(RestClient.Response);
    ShowMessage(response);

    edtPersonelPin.Text = '';
    DashboardSayilariYukle;

  except
    ShowMessage('PIN işlemi yapılamadı: ' + LastExceptionMessage);
  }
}



function KartOlustur(parent: TclVertScrollBox; ad: String; baslik: String; rakam: String; renkKodu: String; altMetin: String): TclProPanel;
var
  pnlKart, pnlCizgi: TclProPanel;
  lblBaslik, lblRakam, lblAltMetin: TclProLabel;
{
  pnlKart = yonetici.AddNewProPanel(parent, ad + '_kart');
  pnlKart.Align = alTop;
  pnlKart.Height = 120;
  pnlKart.Margins.Top = 10;
  pnlKart.Margins.Left = 16;
  pnlKart.Margins.Right = 16;
  pnlKart.clProSettings.BackgroundColor = clAlphaColor.clHexToColor('#FFFFFF');
  pnlKart.clProSettings.IsRound = True;
  pnlKart.clProSettings.RoundHeight = 12;
  pnlKart.clProSettings.RoundWidth = 12;
  pnlKart.clProSettings.BorderColor = clAlphaColor.clHexToColor('#E2E8F0');
  pnlKart.clProSettings.BorderWidth = 1;
  pnlKart.SetclProSettings(pnlKart.clProSettings);

  pnlCizgi = yonetici.AddNewProPanel(pnlKart, ad + '_cizgi');
  pnlCizgi.Align = alTop;
  pnlCizgi.Height = 4;
  pnlCizgi.clProSettings.BackgroundColor = clAlphaColor.clHexToColor(renkKodu);
  pnlCizgi.SetclProSettings(pnlCizgi.clProSettings);

  lblBaslik = yonetici.AddNewProLabel(pnlKart, ad + '_baslik', baslik);
  lblBaslik.Align = alTop;
  lblBaslik.Height = 25;
  lblBaslik.Margins.Left = 16;
  lblBaslik.Margins.Top = 10;
  lblBaslik.clProSettings.FontColor = clAlphaColor.clHexToColor('#64748B');
  lblBaslik.clProSettings.FontSize = 12;
  lblBaslik.clProSettings.TextSettings.Font.Style = [fsBold];
  lblBaslik.SetclProSettings(lblBaslik.clProSettings);

  lblRakam = yonetici.AddNewProLabel(pnlKart, ad + '_rakam', rakam);
  lblRakam.Align = alTop;
  lblRakam.Height = 40;
  lblRakam.Margins.Left = 16;
  lblRakam.clProSettings.FontColor = clAlphaColor.clHexToColor(renkKodu);
  lblRakam.clProSettings.FontSize = 32;
  lblRakam.clProSettings.TextSettings.Font.Style = [fsBold];
  lblRakam.SetclProSettings(lblRakam.clProSettings);

  lblAltMetin = yonetici.AddNewProLabel(pnlKart, ad + '_altmetin', altMetin);
  lblAltMetin.Align = alBottom;
  lblAltMetin.Height = 25;
  lblAltMetin.Margins.Left = 16;
  lblAltMetin.Margins.Bottom = 8;
  lblAltMetin.clProSettings.FontColor = clAlphaColor.clHexToColor('#94A3B8');
  lblAltMetin.clProSettings.FontSize = 11;
  lblAltMetin.SetclProSettings(lblAltMetin.clProSettings);

  if (ad == 'k1')
  {
    lblK1Rakam = lblRakam;
  }
  else if (ad == 'k2')
  {
    lblK2Rakam = lblRakam;
    yonetici.AddNewEvent(pnlKart, tbeOnClick, 'GoToIzinOnay');
    yonetici.AddNewEvent(lblBaslik, tbeOnClick, 'GoToIzinOnay');
    yonetici.AddNewEvent(lblRakam, tbeOnClick, 'GoToIzinOnay');
    yonetici.AddNewEvent(lblAltMetin, tbeOnClick, 'GoToIzinOnay');
  }
  else if (ad == 'k3')
  {
    lblK3Rakam = lblRakam;
    yonetici.AddNewEvent(pnlKart, tbeOnClick, 'EksikPersonelListele');
    yonetici.AddNewEvent(lblBaslik, tbeOnClick, 'EksikPersonelListele');
    yonetici.AddNewEvent(lblRakam, tbeOnClick, 'EksikPersonelListele');
    yonetici.AddNewEvent(lblAltMetin, tbeOnClick, 'EksikPersonelListele');
  }

  Result = pnlKart;
}


void BtnPress
var
  btn: TClProButton;
{
  btn = TClProButton(yonetici.clSender);
  btn.Position.Y = btn.Position.Y + 2;
}


void BtnRelease
var
  btn: TClProButton;
{
  btn = TClProButton(yonetici.clSender);
  btn.Position.Y = btn.Position.Y - 2;
}


void StilButton(btn: TclProButton; bg: String; fg: String)
{
  btn.clProSettings.BackgroundColor = clAlphaColor.clHexToColor(bg);
  btn.clProSettings.FontColor = clAlphaColor.clHexToColor(fg);
  btn.clProSettings.BorderColor = clAlphaColor.clHexToColor('#E2E8F0');
  btn.clProSettings.BorderWidth = 1;
  btn.clProSettings.FontSize = 12;
  btn.clProSettings.IsFill = True;
  btn.clProSettings.IsRound = True;
  btn.clProSettings.RoundHeight = 8;
  btn.clProSettings.RoundWidth = 8;
  btn.clProSettings.TextSettings.Font.Style = [fsBold];
  btn.SetclProSettings(btn.clProSettings);
}



var
  yoneticigiris: TCLForm;

  // Supabase
  RestClient: TclRest;
  SUPABASE_URL: String;
  SUPABASE_KEY: String;

  // Layout
  scrollMain: TClVertScrollBox;
  pnlContent, pnlLogoAlan, pnlFormAlan, pnlDemoAlan, pnlFooter: TclProPanel;

  btnGiris, btnYenikayit: TClProButton;
  lblBaslik, lblAltBaslik, lblSystem, lblDemoTitle, lblDemoInfo: TClProLabel;
  lblEmpId, lblAccessCode: TClProLabel;
  edtEmpId, edtAccessCode: TClProEdit;
  imgLogo: TClProImage;


void SupabaseAyarla
{
  SUPABASE_URL = ''; // Supabase URL removed for GitHub publishing.
  SUPABASE_KEY = ''; // Supabase anon key removed for GitHub publishing.
}


void SetCurrentUser(email: String)
var
  url, body: String;
{
  try
    url = SUPABASE_URL + '/rpc/set_current_user';
    body = '{"p_email":"' + email + '"}';

    RestClient = TclRest.Create;
    RestClient.BaseURL = url;
    RestClient.Accept = 'application/json';
    RestClient.ContentType = 'application/json';
    RestClient.Method = rmPOST;

    RestClient.AddHeader('apikey', SUPABASE_KEY);
    RestClient.AddHeader('Authorization', 'Bearer ' + SUPABASE_KEY);

    RestClient.Body = body;
    RestClient.Execute;

  except
    ShowMessage('Oturum bilgisi kaydedilemedi.');
  }
}


void GoToYonetici
var
  email, sifre, url, response: String;
{
  email = edtEmpId.Text;
  sifre = edtAccessCode.Text;

  if (email == '')
  {
    ShowMessage('E-posta boş bırakılamaz.');
  }
  else if (sifre == '')
  {
    ShowMessage('Şifre boş bırakılamaz.');
  }
  else
  {
    try
      url = SUPABASE_URL + '/users?email=eq.' + email + '&password=eq.' + sifre + '&role=eq.admin&select=id,full_name,email,role';

      RestClient = TclRest.Create;
      RestClient.BaseURL = url;
      RestClient.Accept = 'application/json';
      RestClient.ContentType = 'application/json';
      RestClient.Method = rmGET;

      RestClient.AddHeader('apikey', SUPABASE_KEY);
      RestClient.AddHeader('Authorization', 'Bearer ' + SUPABASE_KEY);

      RestClient.Execute;

      response = RestClient.Response;

      if (response == '[]')
      {
        ShowMessage('Yönetici e-posta veya şifre hatalı.');
      }
      else
      {
        ShowMessage('Yönetici girişi başarılı.');
        SetCurrentUser(email);
        yoneticigiris.clHide;
        Clomosy.RunUnit('yonetici');
      }

    except
      ShowMessage('Yönetici giriş bağlantı hatası: ' + LastExceptionClassName + ' - ' + LastExceptionMessage);
    }
  }
}


void GoToYenikayit
{
  yoneticigiris.clHide;
  Clomosy.RunUnit('yenikayit');
}


void BtnPress
var 
  btn: TClProButton;
{
  btn = TClProButton(yoneticigiris.clSender);
  btn.Position.Y = btn.Position.Y + 4;
}


void BtnRelease
var 
  btn: TClProButton;
{
  btn = TClProButton(yoneticigiris.clSender);
  btn.Position.Y = btn.Position.Y - 4;
}


{

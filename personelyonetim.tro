  btnDuzenle.clProSettings.FontSize = 12;
  btnDuzenle.clProSettings.IsRound = True;
  btnDuzenle.clProSettings.RoundHeight = 8;
  btnDuzenle.clProSettings.RoundWidth = 8;
  btnDuzenle.clProSettings.TextSettings.Font.Style = [fsBold];
  btnDuzenle.SetclProSettings(btnDuzenle.clProSettings);
  personelyonetim.AddNewEvent(btnDuzenle, tbeOnClick, 'PersonelDuzenleSec');

  btnSil = personelyonetim.AddNewProButton(pnlAlt, 'btnSil_' + IntToStr(index), 'Sil');
  btnSil.Align = alRight;
  btnSil.Width = 75;
  btnSil.TagString = idText;
  btnSil.clProSettings.BackgroundColor = clAlphaColor.clHexToColor('#FEE2E2');
  btnSil.clProSettings.FontColor = clAlphaColor.clHexToColor('#DC2626');
  btnSil.clProSettings.BorderWidth = 0;
  btnSil.clProSettings.FontSize = 12;
  btnSil.clProSettings.IsRound = True;
  btnSil.clProSettings.RoundHeight = 8;
  btnSil.clProSettings.RoundWidth = 8;
  btnSil.clProSettings.TextSettings.Font.Style = [fsBold];
  btnSil.SetclProSettings(btnSil.clProSettings);
  personelyonetim.AddNewEvent(btnSil, tbeOnClick, 'PersonelSil');
}


void PersonelleriYukle
var
  url, response, kalan, kayit: String;
  bitis, index: Integer;
{
  try
    url = SUPABASE_URL + '/rpc/list_personel_manage';

    RestClient = TclRest.Create;
    RestClient.BaseURL = url;
    RestClient.Accept = 'application/json';
    RestClient.ContentType = 'application/json';
    RestClient.Method = rmPOST;
    RestClient.AddHeader('apikey', SUPABASE_KEY);
    RestClient.AddHeader('Authorization', 'Bearer ' + SUPABASE_KEY);
    RestClient.Body = '{}';
    RestClient.Execute;

    response = SupabaseTextTemizle(RestClient.Response);

    if (response == '')
    {
      BilgiKartOlustur('Kayıtlı personel bulunamadı.');
      exit;
    }

    if (response == 'null')
    {
      BilgiKartOlustur('Kayıtlı personel bulunamadı.');
      exit;
    }

    if (response == '[]')
    {
      BilgiKartOlustur('Kayıtlı personel bulunamadı.');
      exit;
    }

    if (response == '0')
    {
      BilgiKartOlustur('Personel listesi boş döndü.');
      exit;
    }

    if (Copy(response, 1, 1) == '{')
    {
      BilgiKartOlustur('Supabase hatası: ' + response);
      exit;
    }

    if (Pos('|', response) <= 0)
    {
      BilgiKartOlustur('Personel liste formatı okunamadı: ' + response);
      exit;
    }

    kalan = response;
    index = 0;

    while (Length(kalan) > 0)
    {
      bitis = Pos(';;', kalan);

      if (bitis > 0)
      {
        kayit = Copy(kalan, 1, bitis - 1);
        kalan = Copy(kalan, bitis + 2, Length(kalan));
      }
      else
      {
        kayit = kalan;
        kalan = '';
      }

      if (Pos('|', kayit) > 0)
      {
        PersonelKartOlustur(index, kayit);
        index = index + 1;
      }
    }

    if (index == 0)
    {
      BilgiKartOlustur('Personel kaydı okunamadı. Gelen veri: ' + response);
    }

  except
    BilgiKartOlustur('Personel listesi alınamadı: ' + LastExceptionClassName + ' - ' + LastExceptionMessage);
  }
}


void PersonelEkle
var
  ad, email, sifre, departman, pozisyon: String;
  url, body, response: String;
{
  ad = edtAd.Text;
  email = edtEmail.Text;
  sifre = edtSifre.Text;
  departman = edtDepartman.Text;
  pozisyon = edtPozisyon.Text;

  if (ad == '')
  {
    ShowMessage('Ad soyad boş bırakılamaz.');
    exit;
  }

  if (email == '')
  {
    ShowMessage('E-posta boş bırakılamaz.');
    exit;
  }

  if (sifre == '')
  {
    ShowMessage('Şifre boş bırakılamaz.');
    exit;
  }

  if (departman == '')
    departman = '-';

  if (pozisyon == '')
    pozisyon = '-';

  if (duzenlemeModu == True)
  {
    if (seciliUserId == '')
    {
      ShowMessage('Güncellenecek personel seçilmedi.');
      exit;
    }

    url = SUPABASE_URL + '/rpc/update_personel_manage';

    body = '{"p_user_id":' + seciliUserId +
           ',"p_full_name":"' + ad +
           '","p_email":"' + email +
           '","p_password":"' + sifre +
           '","p_department":"' + departman +
           '","p_position":"' + pozisyon + '"}';
  }
  else
  {
    url = SUPABASE_URL + '/rpc/create_personel_manage';

    body = '{"p_full_name":"' + ad +
           '","p_email":"' + email +
           '","p_password":"' + sifre +
           '","p_department":"' + departman +
           '","p_position":"' + pozisyon + '"}';
  }

  try
    RestClient = TclRest.Create;
    RestClient.BaseURL = url;
    RestClient.Accept = 'application/json';
    RestClient.ContentType = 'application/json';
    RestClient.Method = rmPOST;
    RestClient.AddHeader('apikey', SUPABASE_KEY);
    RestClient.AddHeader('Authorization', 'Bearer ' + SUPABASE_KEY);
    RestClient.Body = body;
    RestClient.Execute;

    response = SupabaseTextTemizle(RestClient.Response);

    if (response == '')
    {
      if (duzenlemeModu == True)
        ShowMessage('Personel bilgileri güncellendi.')
      else
        ShowMessage('Personel oluşturuldu.');
    }
    else
    {
      ShowMessage(response);
    }

    SayfayiYenile;

  except
    ShowMessage('Personel işlemi yapılamadı: ' + LastExceptionClassName + ' - ' + LastExceptionMessage);
  }
}



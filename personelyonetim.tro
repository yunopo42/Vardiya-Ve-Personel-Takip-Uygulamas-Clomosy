var
  personelyonetim: TCLForm;

  RestClient: TclRest;
  SUPABASE_URL: String;
  SUPABASE_KEY: String;

  pnlTop, pnlForm, pnlButtons: TclProPanel;
  lblBaslik, lblFormBaslik, lblListeBaslik: TclProLabel;
  btnGeri, btnYenile, btnEkle, btnTemizle: TclProButton;
  edtAd, edtEmail, edtSifre, edtDepartman, edtPozisyon: TClEdit;

  scrollListe: TClVertScrollBox;
  listeNo: Integer;

  duzenlemeModu: Boolean;
  seciliUserId: String;


void SupabaseAyarla
{
  SUPABASE_URL = ''; // Supabase URL removed for GitHub publishing.
  SUPABASE_KEY = ''; // Supabase anon key removed for GitHub publishing.
}


function SupabaseTextTemizle(metin: String): String;
var
  sonuc: String;
{
  sonuc = metin;

  if (sonuc == '""')
  {
    Result = '';
    exit;
  }

  if (Length(sonuc) > 0)
  {
    if (Copy(sonuc, 1, 1) == '"')
      sonuc = Copy(sonuc, 2, Length(sonuc));
  }

  if (Length(sonuc) > 0)
  {
    if (Copy(sonuc, Length(sonuc), 1) == '"')
      sonuc = Copy(sonuc, 1, Length(sonuc) - 1);
  }

  Result = sonuc;
}


function ParcaAl(metin: String; ayirac: String; index: Integer): String;
var
  i, p: Integer;
  kalan, parca: String;
{
  kalan = metin;
  parca = '';

  for i = 1 to index
  {
    p = Pos(ayirac, kalan);

    if (p > 0)
    {
      parca = Copy(kalan, 1, p - 1);
      kalan = Copy(kalan, p + Length(ayirac), Length(kalan));
    }
    else
    {
      parca = kalan;
      kalan = '';
    }
  }

  Result = parca;
}


void GoBack
{
  personelyonetim.clHide;
  Clomosy.RunUnit('yonetici');
}


void SayfayiYenile
{
  personelyonetim.clHide;
  Clomosy.RunUnit('personelyonetim');
}


void FormuTemizle
{
  duzenlemeModu = False;
  seciliUserId = '';

  edtAd.Text = '';
  edtEmail.Text = '';
  edtSifre.Text = '';
  edtDepartman.Text = '';
  edtPozisyon.Text = '';

  lblFormBaslik.Text = 'Yeni Personel Ekle';
  btnEkle.Text = 'Personel Ekle';

  lblFormBaslik.SetclProSettings(lblFormBaslik.clProSettings);
  btnEkle.SetclProSettings(btnEkle.clProSettings);
}


void BilgiKartOlustur(metin: String)
var
  pnlKart: TclProPanel;
  lblInfo: TclProLabel;
{
  listeNo = listeNo + 1;

  pnlKart = personelyonetim.AddNewProPanel(scrollListe, 'pnlInfo_' + IntToStr(listeNo));
  pnlKart.Align = alTop;
  pnlKart.Height = 100;
  pnlKart.Margins.Left = 14;
  pnlKart.Margins.Right = 14;
  pnlKart.Margins.Top = 14;
  pnlKart.clProSettings.BackgroundColor = clAlphaColor.clHexToColor('#FFFFFF');
  pnlKart.clProSettings.BorderColor = clAlphaColor.clHexToColor('#E2E8F0');
  pnlKart.clProSettings.BorderWidth = 1;
  pnlKart.clProSettings.IsRound = True;
  pnlKart.clProSettings.RoundHeight = 14;
  pnlKart.clProSettings.RoundWidth = 14;
  pnlKart.SetclProSettings(pnlKart.clProSettings);

  lblInfo = personelyonetim.AddNewProLabel(pnlKart, 'lblInfo_' + IntToStr(listeNo), metin);
  lblInfo.Align = alClient;
  lblInfo.Margins.Left = 16;
  lblInfo.Margins.Right = 16;
  lblInfo.clProSettings.FontColor = clAlphaColor.clHexToColor('#64748B');
  lblInfo.clProSettings.FontSize = 13;
  lblInfo.clProSettings.FontVertAlign = palCenter;
  lblInfo.clProSettings.TextSettings.WordWrap = True;
  lblInfo.SetclProSettings(lblInfo.clProSettings);
}


void PersonelDuzenleSec
var
  btn: TClProButton;
  data: String;
{
  btn = TClProButton(personelyonetim.clSender);
  data = btn.TagString;

  seciliUserId = ParcaAl(data, '|', 1);
  edtAd.Text = ParcaAl(data, '|', 2);
  edtEmail.Text = ParcaAl(data, '|', 3);
  edtDepartman.Text = ParcaAl(data, '|', 4);
  edtPozisyon.Text = ParcaAl(data, '|', 5);
  edtSifre.Text = ParcaAl(data, '|', 6);

  duzenlemeModu = True;

  lblFormBaslik.Text = 'Personel Düzenle';
  btnEkle.Text = 'Personeli Güncelle';

  lblFormBaslik.SetclProSettings(lblFormBaslik.clProSettings);
  btnEkle.SetclProSettings(btnEkle.clProSettings);

  ShowMessage('Personel bilgileri forma aktarıldı. Düzenleyip Personeli Güncelle butonuna bas.');
}


void PersonelDurumGuncelle
var
  btn: TClProButton;
  data, userId, yeniDurum: String;
  p: Integer;
  url, body, response: String;
{
  btn = TClProButton(personelyonetim.clSender);
  data = btn.TagString;

  p = Pos('|', data);

  if (p <= 0)
  {
    ShowMessage('Personel bilgisi okunamadı.');
    exit;
  }

  userId = Copy(data, 1, p - 1);
  yeniDurum = Copy(data, p + 1, Length(data));

  url = SUPABASE_URL + '/rpc/update_personel_status_manage';
  body = '{"p_user_id":' + userId + ',"p_status":"' + yeniDurum + '"}';

  try
    RestClient = TclRest.Create;
    RestClient.BaseURL = url;
    RestClient.Accept = 'application/json';
    RestClient.ContentType = 'application/json';
    RestClient.Method = rmPOST;
    RestClient.AddHeader('apikey', SUPABASE_KEY);
    RestClient.AddHeader('Authorization', 'Bearer ' + SUPABASE_KEY);
    RestClient.Body = body;
    RestClient.Execute;

    response = SupabaseTextTemizle(RestClient.Response);

    if (response == '')
      ShowMessage('Personel durumu güncellendi.')
    else
      ShowMessage(response);

    SayfayiYenile;

  except
    ShowMessage('Personel durumu güncellenemedi: ' + LastExceptionClassName + ' - ' + LastExceptionMessage);
  }
}


void PersonelSil
var
  btn: TClProButton;
  userId, url, body, response: String;
{
  btn = TClProButton(personelyonetim.clSender);
  userId = btn.TagString;

  if (userId == '')
  {
    ShowMessage('Silinecek personel ID bilgisi alınamadı.');
    exit;
  }

  url = SUPABASE_URL + '/rpc/delete_personel_manage';
  body = '{"p_user_id":' + userId + '}';

  try
    RestClient = TclRest.Create;
    RestClient.BaseURL = url;
    RestClient.Accept = 'application/json';
    RestClient.ContentType = 'application/json';
    RestClient.Method = rmPOST;
    RestClient.AddHeader('apikey', SUPABASE_KEY);
    RestClient.AddHeader('Authorization', 'Bearer ' + SUPABASE_KEY);
    RestClient.Body = body;
    RestClient.Execute;

    response = SupabaseTextTemizle(RestClient.Response);

    if (response == '')
      ShowMessage('Personel silindi.')
    else
      ShowMessage(response);

    SayfayiYenile;

  except
    ShowMessage('Personel silinemedi: ' + LastExceptionClassName + ' - ' + LastExceptionMessage);
  }
}


void PersonelKartOlustur(index: Integer; kayit: String)
var
  pnlKart, pnlSol, pnlAlt: TclProPanel;
  lblAd, lblBilgi, lblDurum: TclProLabel;
  btnDurum, btnDuzenle, btnSil: TclProButton;
  idText, ad, email, departman, pozisyon, durum, yeniDurum, sifre: String;
{
  idText = ParcaAl(kayit, '|', 1);
  ad = ParcaAl(kayit, '|', 2);
  email = ParcaAl(kayit, '|', 3);
  departman = ParcaAl(kayit, '|', 4);
  pozisyon = ParcaAl(kayit, '|', 5);
  durum = ParcaAl(kayit, '|', 6);

  if (idText == '')
    idText = '-';

  if (ad == '')
    ad = 'İsimsiz Personel';

  if (email == '')
    email = '-';

  if (departman == '')
    departman = '-';

  if (pozisyon == '')
    pozisyon = '-';

  if (durum == '')
    durum = 'Aktif';

  sifre = '123456';

  pnlKart = personelyonetim.AddNewProPanel(scrollListe, 'pnlPersonel_' + IntToStr(index));
  pnlKart.Align = alTop;
  pnlKart.Height = 160;
  pnlKart.Margins.Left = 14;
  pnlKart.Margins.Right = 14;
  pnlKart.Margins.Top = 10;
  pnlKart.clProSettings.BackgroundColor = clAlphaColor.clHexToColor('#FFFFFF');
  pnlKart.clProSettings.BorderColor = clAlphaColor.clHexToColor('#E2E8F0');
  pnlKart.clProSettings.BorderWidth = 1;
  pnlKart.clProSettings.IsRound = True;
  pnlKart.clProSettings.RoundHeight = 14;
  pnlKart.clProSettings.RoundWidth = 14;
  pnlKart.SetclProSettings(pnlKart.clProSettings);

  pnlSol = personelyonetim.AddNewProPanel(pnlKart, 'pnlSol_' + IntToStr(index));
  pnlSol.Align = alLeft;
  pnlSol.Width = 6;

  if (durum == 'Aktif')
    pnlSol.clProSettings.BackgroundColor = clAlphaColor.clHexToColor('#10B981')
  else
    pnlSol.clProSettings.BackgroundColor = clAlphaColor.clHexToColor('#EF4444');

  pnlSol.SetclProSettings(pnlSol.clProSettings);

  lblAd = personelyonetim.AddNewProLabel(pnlKart, 'lblAd_' + IntToStr(index), ad);
  lblAd.Align = alTop;
  lblAd.Height = 28;
  lblAd.Margins.Left = 16;
  lblAd.Margins.Right = 12;
  lblAd.Margins.Top = 10;
  lblAd.clProSettings.FontColor = clAlphaColor.clHexToColor('#0F172A');
  lblAd.clProSettings.FontSize = 15;
  lblAd.clProSettings.TextSettings.Font.Style = [fsBold];
  lblAd.SetclProSettings(lblAd.clProSettings);

  lblBilgi = personelyonetim.AddNewProLabel(pnlKart, 'lblBilgi_' + IntToStr(index), email + #13#10 + departman + ' | ' + pozisyon);
  lblBilgi.Align = alTop;
  lblBilgi.Height = 42;
  lblBilgi.Margins.Left = 16;
  lblBilgi.Margins.Right = 12;
  lblBilgi.clProSettings.FontColor = clAlphaColor.clHexToColor('#64748B');
  lblBilgi.clProSettings.FontSize = 11;
  lblBilgi.clProSettings.TextSettings.WordWrap = True;
  lblBilgi.SetclProSettings(lblBilgi.clProSettings);

  lblDurum = personelyonetim.AddNewProLabel(pnlKart, 'lblDurum_' + IntToStr(index), 'Durum: ' + durum);
  lblDurum.Align = alTop;
  lblDurum.Height = 24;
  lblDurum.Margins.Left = 16;
  lblDurum.Margins.Right = 12;
  lblDurum.clProSettings.FontColor = clAlphaColor.clHexToColor('#334155');
  lblDurum.clProSettings.FontSize = 12;
  lblDurum.clProSettings.FontVertAlign = palCenter;
  lblDurum.SetclProSettings(lblDurum.clProSettings);

  pnlAlt = personelyonetim.AddNewProPanel(pnlKart, 'pnlAlt_' + IntToStr(index));
  pnlAlt.Align = alBottom;
  pnlAlt.Height = 45;
  pnlAlt.Margins.Left = 16;
  pnlAlt.Margins.Right = 12;
  pnlAlt.Margins.Bottom = 10;
  pnlAlt.clProSettings.BackgroundColor = clAlphaColor.clHexToColor('#FFFFFF');
  pnlAlt.SetclProSettings(pnlAlt.clProSettings);

  if (durum == 'Aktif')
    yeniDurum = 'Pasif'
  else
    yeniDurum = 'Aktif';

  btnDurum = personelyonetim.AddNewProButton(pnlAlt, 'btnDurum_' + IntToStr(index), yeniDurum);
  btnDurum.Align = alLeft;
  btnDurum.Width = 82;
  btnDurum.TagString = idText + '|' + yeniDurum;

  if (yeniDurum == 'Pasif')
  {
    btnDurum.clProSettings.BackgroundColor = clAlphaColor.clHexToColor('#FEE2E2');
    btnDurum.clProSettings.FontColor = clAlphaColor.clHexToColor('#DC2626');
  }
  else
  {
    btnDurum.clProSettings.BackgroundColor = clAlphaColor.clHexToColor('#DCFCE7');
    btnDurum.clProSettings.FontColor = clAlphaColor.clHexToColor('#16A34A');
  }

  btnDurum.clProSettings.BorderWidth = 0;
  btnDurum.clProSettings.FontSize = 12;
  btnDurum.clProSettings.IsRound = True;
  btnDurum.clProSettings.RoundHeight = 8;
  btnDurum.clProSettings.RoundWidth = 8;
  btnDurum.clProSettings.TextSettings.Font.Style = [fsBold];
  btnDurum.SetclProSettings(btnDurum.clProSettings);
  personelyonetim.AddNewEvent(btnDurum, tbeOnClick, 'PersonelDurumGuncelle');

  btnDuzenle = personelyonetim.AddNewProButton(pnlAlt, 'btnDuzenle_' + IntToStr(index), 'Düzenle');

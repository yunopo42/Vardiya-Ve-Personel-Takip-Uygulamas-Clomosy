  btnEkle = personelyonetim.AddNewProButton(pnlForm, 'btnEkle', 'Personel Ekle');
  btnEkle.Align = alTop;
  btnEkle.Height = 40;
  btnEkle.Margins.Left = 14;
  btnEkle.Margins.Right = 14;
  btnEkle.Margins.Top = 10;
  btnEkle.clProSettings.FontColor = clAlphaColor.clHexToColor('#FFFFFF');
  btnEkle.clProSettings.BackgroundColor = clAlphaColor.clHexToColor('#1E3A8A');
  btnEkle.clProSettings.BorderWidth = 0;
  btnEkle.clProSettings.IsRound = True;
  btnEkle.clProSettings.RoundHeight = 8;
  btnEkle.clProSettings.RoundWidth = 8;
  btnEkle.clProSettings.TextSettings.Font.Style = [fsBold];
  btnEkle.SetclProSettings(btnEkle.clProSettings);
  personelyonetim.AddNewEvent(btnEkle, tbeOnClick, 'PersonelEkle');

  btnTemizle = personelyonetim.AddNewProButton(pnlForm, 'btnTemizle', 'Temizle / Yeni Kayıt');
  btnTemizle.Align = alTop;
  btnTemizle.Height = 36;
  btnTemizle.Margins.Left = 14;

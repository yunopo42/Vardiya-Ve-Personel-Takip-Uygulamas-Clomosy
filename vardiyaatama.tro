{
  TarihSec(0, btnGun1);
}


void GunSec2
{
  TarihSec(1, btnGun2);
}


void GunSec3
{
  TarihSec(2, btnGun3);
}


void GunSec4
{
  TarihSec(3, btnGun4);
}


void GunSec5
{
  TarihSec(4, btnGun5);
}


void GunSec6
{
  TarihSec(5, btnGun6);
}


void GunSec7
{
  TarihSec(6, btnGun7);
}



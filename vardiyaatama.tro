void VardiyaEkle
var
  url, body, response: String;
{
  try
    url = SUPABASE_URL + '/rpc/assign_shift_by_email';

    body = '{"p_email":"' + seciliPersonelEmail +
           '","p_shift_date":"' + seciliTarih +
           '","p_shift_type":"' + seciliVardiya +
           '","p_start_time":"' + seciliBaslangic +
           '","p_end_time":"' + seciliBitis +
           '","p_department":"' + seciliPersonelDept + '"}';

    RestClient = TclRest.Create;
    RestClient.BaseURL = url;
    RestClient.Accept = 'application/json';
    RestClient.ContentType = 'application/json';
    RestClient.Method = rmPOST;

    RestClient.AddHeader('apikey', SUPABASE_KEY);
    RestClient.AddHeader('Authorization', 'Bearer ' + SUPABASE_KEY);

    RestClient.Body = body;
    RestClient.Execute;

    response = RestClient.Response;
    response = SupabaseTextTemizle(response);

    if (response == '')
      ShowMessage('Vardiya işlemi tamamlandı.')
    else
      ShowMessage(response);

    ListeyiYukle;

  except
    ShowMessage('Vardiya kaydı hatası: ' + LastExceptionMessage);
  }
}


void VardiyaGuncelle
var
  url, body, response: String;
{
  try
    url = SUPABASE_URL + '/rpc/update_shift_by_id';

    body = '{"p_shift_id":"' + seciliShiftId +
           '","p_shift_type":"' + seciliVardiya +
           '","p_start_time":"' + seciliBaslangic +
           '","p_end_time":"' + seciliBitis + '"}';

    RestClient = TclRest.Create;
    RestClient.BaseURL = url;
    RestClient.Accept = 'application/json';
    RestClient.ContentType = 'application/json';
    RestClient.Method = rmPOST;

    RestClient.AddHeader('apikey', SUPABASE_KEY);
    RestClient.AddHeader('Authorization', 'Bearer ' + SUPABASE_KEY);

    RestClient.Body = body;
    RestClient.Execute;

    response = RestClient.Response;
    response = SupabaseTextTemizle(response);

    if (response == '')
      ShowMessage('Vardiya güncellendi.')
    else
      ShowMessage(response);

    duzenlemeModu = False;
    seciliShiftId = '';
    btnKaydet.Text = '+ Vardiyaya Ekle';
    btnKaydet.SetclProSettings(btnKaydet.clProSettings);

    ListeyiYukle;

  except
    ShowMessage('Vardiya güncelleme hatası: ' + LastExceptionMessage);
  }
}


void VardiyaKaydet
{
  if (seciliTarih < FormatDateTime('yyyy-mm-dd', Now))
  {
    ShowMessage('Geçmiş tarih için vardiya atanamaz.');
    exit;
  }

  if (duzenlemeModu == True)
  {
    if (seciliShiftId == '')
    {
      ShowMessage('Düzenlenecek vardiya seçilmedi.');
    }
    else if (seciliVardiya == '')
    {
      ShowMessage('Yeni vardiya türünü seçmelisin.');
    }
    else
    {
      VardiyaGuncelle;
    }
  }
  else
  {
    if (seciliPersonelEmail == '')
    {
      ShowMessage('Önce personel seçmelisin.');
    }
    else if (seciliTarih == '')
    {
      ShowMessage('Önce gün seçmelisin.');
    }
    else if (seciliVardiya == '')
    {
      ShowMessage('Önce vardiya seçmelisin.');
    }
    else
    {
      VardiyaEkle;
    }
  }
}


void VardiyaSil
var
  btn: TClProButton;
  url, body, response: String;
{
  btn = TClProButton(vardiyaatama.clSender);

  try
    url = SUPABASE_URL + '/rpc/delete_shift_by_id';
    body = '{"p_shift_id":"' + btn.TagString + '"}';

    RestClient = TclRest.Create;
    RestClient.BaseURL = url;
    RestClient.Accept = 'application/json';
    RestClient.ContentType = 'application/json';
    RestClient.Method = rmPOST;

    RestClient.AddHeader('apikey', SUPABASE_KEY);
    RestClient.AddHeader('Authorization', 'Bearer ' + SUPABASE_KEY);

    RestClient.Body = body;
    RestClient.Execute;

    response = RestClient.Response;
    response = SupabaseTextTemizle(response);

    if (response == '')
      ShowMessage('Vardiya silindi.')
    else
      ShowMessage(response);

    ListeyiYukle;

  except
    ShowMessage('Vardiya silme hatası: ' + LastExceptionMessage);
  }
}


void VardiyaDuzenle
var
  btn: TClProButton;
  data, shiftId, adSoyad, vardiya, basSaat, bitSaat: String;
  p1, p2, p3, p4: Integer;
{
  btn = TClProButton(vardiyaatama.clSender);
  data = btn.TagString;

  p1 = Pos('|', data);
  shiftId = Copy(data, 1, p1 - 1);
  data = Copy(data, p1 + 1, Length(data));

  p2 = Pos('|', data);
  adSoyad = Copy(data, 1, p2 - 1);
  data = Copy(data, p2 + 1, Length(data));

  p3 = Pos('|', data);
  vardiya = Copy(data, 1, p3 - 1);
  data = Copy(data, p3 + 1, Length(data));

  p4 = Pos('|', data);
  basSaat = Copy(data, 1, p4 - 1);
  bitSaat = Copy(data, p4 + 1, Length(data));

  seciliShiftId = shiftId;
  duzenlemeModu = True;

  btnKaydet.Text = 'Vardiyayı Güncelle';
  btnKaydet.SetclProSettings(btnKaydet.clProSettings);

  ShowMessage(adSoyad + ' için yeni vardiya seçip Vardiyayı Güncelle butonuna bas.');
}


{
  SupabaseAyarla;

  seciliTarih = '';
  seciliGunAdi = '';
  seciliVardiya = '';
  seciliBaslangic = '';
  seciliBitis = '';

  seciliPersonelAd = '';
  seciliPersonelEmail = '';

  seciliVardiya = 'Sabah';
  seciliBaslangic = '08:00';
  seciliBitis = '17:00';
}


void VardiyaSecAksam
{
  VardiyaButonlariniSifirla;
  SetButtonActive(btnAksam);
  seciliVardiya = 'Akşam';
  seciliBaslangic = '16:00';
  seciliBitis = '00:00';
}


void VardiyaSecGece
{
  VardiyaButonlariniSifirla;
  SetButtonActive(btnGece);
  seciliVardiya = 'Gece';
  seciliBaslangic = '00:00';
  seciliBitis = '08:00';

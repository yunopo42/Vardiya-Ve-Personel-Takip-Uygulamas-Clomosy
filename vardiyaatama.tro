var
  vardiyaatama: TCLForm;

  RestClient: TclRest;
  SUPABASE_URL: String;
  SUPABASE_KEY: String;

  pnlHeader, pnlContent: TclProPanel;
  scrollMain: TClVertScrollBox;

  pnlPersonelAlan, pnlGunler, pnlGunRow1, pnlGunRow2, pnlGunRow3, pnlGunRow4, pnlVardiya: TclProPanel;
  pnlListeAlan: TclProPanel;

  scrollPersonel: TClVertScrollBox;
  scrollVardiyalar: TClVertScrollBox;

  lblBaslik, lblPersonelBaslik, lblSeciliPersonel: TclProLabel;
  lblGunBaslik, lblVardiyaBaslik, lblListeBaslik: TclProLabel;

  btnGeri, btnPersonelAra: TclProButton;
  btnGun1, btnGun2, btnGun3, btnGun4, btnGun5, btnGun6, btnGun7: TclProButton;
  btnSabah, btnAksam, btnGece, btnKaydet, btnYenile: TclProButton;

  edtPersonelAra: TclProEdit;

  seciliTarih, seciliGunAdi: String;
  seciliVardiya, seciliBaslangic, seciliBitis: String;
  seciliPersonelAd, seciliPersonelEmail, seciliPersonelDept: String;

  duzenlemeModu: Boolean;
  seciliShiftId: String;

  personelListeNo, vardiyaListeNo: Integer;


void SupabaseAyarla
{
  SUPABASE_URL = ''; // Supabase URL removed for GitHub publishing.
  SUPABASE_KEY = ''; // Supabase anon key removed for GitHub publishing.
}


void GoBack
{
  vardiyaatama.clHide;
  Clomosy.RunUnit('yonetici');
}


function SupabaseTextTemizle(metin: String): String;
var
  sonuc: String;
{
  sonuc = metin;

  if (sonuc == '""')
  {
    sonuc = '';
    Result = sonuc;
    exit;
  }

  if (Length(sonuc) > 0)
  {
    if (Copy(sonuc, 1, 1) == '"')
      sonuc = Copy(sonuc, 2, Length(sonuc));
  }

  if (Length(sonuc) > 0)
  {
    if (Copy(sonuc, Length(sonuc), 1) == '"')
      sonuc = Copy(sonuc, 1, Length(sonuc) - 1);
  }

  Result = sonuc;
}


void SetButtonPassive(btn: TclProButton)
{
  btn.clProSettings.BackgroundColor = clAlphaColor.clHexToColor('#FFFFFF');
  btn.clProSettings.FontColor = clAlphaColor.clHexToColor('#0F172A');
  btn.clProSettings.BorderColor = clAlphaColor.clHexToColor('#E2E8F0');
  btn.clProSettings.BorderWidth = 1;
  btn.clProSettings.IsRound = True;
  btn.clProSettings.RoundHeight = 8;
  btn.clProSettings.RoundWidth = 8;
  btn.clProSettings.FontHorzAlign = palCenter;
  btn.clProSettings.FontVertAlign = palCenter;
  btn.SetclProSettings(btn.clProSettings);
}


void SetButtonActive(btn: TclProButton)
{
  btn.clProSettings.BackgroundColor = clAlphaColor.clHexToColor('#1E3A8A');
  btn.clProSettings.FontColor = clAlphaColor.clHexToColor('#FFFFFF');
  btn.clProSettings.BorderColor = clAlphaColor.clHexToColor('#1E3A8A');
  btn.clProSettings.BorderWidth = 1;
  btn.clProSettings.IsRound = True;
  btn.clProSettings.RoundHeight = 8;
  btn.clProSettings.RoundWidth = 8;
  btn.clProSettings.FontHorzAlign = palCenter;
  btn.clProSettings.FontVertAlign = palCenter;
  btn.SetclProSettings(btn.clProSettings);
}


void GunButonlariniSifirla
{
  SetButtonPassive(btnGun1);
  SetButtonPassive(btnGun2);
  SetButtonPassive(btnGun3);
  SetButtonPassive(btnGun4);
  SetButtonPassive(btnGun5);
  SetButtonPassive(btnGun6);
  SetButtonPassive(btnGun7);
}


void VardiyaButonlariniSifirla
{
  SetButtonPassive(btnSabah);
  SetButtonPassive(btnAksam);
  SetButtonPassive(btnGece);
}


void GunButonYazilariniHazirla
{
  btnGun1.Text = 'Bugün ' + FormatDateTime('dd.mm', Now);
  btnGun2.Text = 'Yarın ' + FormatDateTime('dd.mm', Now + 1);
  btnGun3.Text = FormatDateTime('dd.mm', Now + 2);
  btnGun4.Text = FormatDateTime('dd.mm', Now + 3);
  btnGun5.Text = FormatDateTime('dd.mm', Now + 4);
  btnGun6.Text = FormatDateTime('dd.mm', Now + 5);
  btnGun7.Text = FormatDateTime('dd.mm', Now + 6);

  btnGun1.SetclProSettings(btnGun1.clProSettings);
  btnGun2.SetclProSettings(btnGun2.clProSettings);
  btnGun3.SetclProSettings(btnGun3.clProSettings);
  btnGun4.SetclProSettings(btnGun4.clProSettings);
  btnGun5.SetclProSettings(btnGun5.clProSettings);
  btnGun6.SetclProSettings(btnGun6.clProSettings);
  btnGun7.SetclProSettings(btnGun7.clProSettings);
}


void PersonelSec
var
  btn: TClProButton;
  data: String;
  p1, p2: Integer;
{
  btn = TClProButton(vardiyaatama.clSender);
  data = btn.TagString;

  p1 = Pos('|', data);

  if (p1 > 0)
  {
    seciliPersonelAd = Copy(data, 1, p1 - 1);
    data = Copy(data, p1 + 1, Length(data));

    p2 = Pos('|', data);

    if (p2 > 0)
    {
      seciliPersonelEmail = Copy(data, 1, p2 - 1);
      seciliPersonelDept = Copy(data, p2 + 1, Length(data));
    }
  }

  lblSeciliPersonel.Text = 'Seçili personel: ' + seciliPersonelAd + ' | ' + seciliPersonelDept;
  lblSeciliPersonel.SetclProSettings(lblSeciliPersonel.clProSettings);

  btn.clProSettings.BackgroundColor = clAlphaColor.clHexToColor('#DBEAFE');
  btn.clProSettings.FontColor = clAlphaColor.clHexToColor('#1E3A8A');
  btn.clProSettings.BorderColor = clAlphaColor.clHexToColor('#1E3A8A');
  btn.SetclProSettings(btn.clProSettings);
}


void PersonelButonuOlustur(index: Integer; adSoyad: String; email: String; departman: String)
var
  btn: TClProButton;
{
  btn = vardiyaatama.AddNewProButton(scrollPersonel, 'btnPersonel' + IntToStr(personelListeNo) + '_' + IntToStr(index), adSoyad + ' | ' + departman);

  btn.Align = alTop;
  btn.Height = 42;
  btn.Margins.Top = 6;
  btn.Margins.Left = 8;
  btn.Margins.Right = 8;
  btn.TagString = adSoyad + '|' + email + '|' + departman;

  btn.clProSettings.BackgroundColor = clAlphaColor.clHexToColor('#FFFFFF');
  btn.clProSettings.FontColor = clAlphaColor.clHexToColor('#0F172A');
  btn.clProSettings.BorderColor = clAlphaColor.clHexToColor('#E2E8F0');
  btn.clProSettings.BorderWidth = 1;
  btn.clProSettings.FontSize = 12;
  btn.clProSettings.IsRound = True;
  btn.clProSettings.RoundHeight = 8;
  btn.clProSettings.RoundWidth = 8;
  btn.SetclProSettings(btn.clProSettings);

  vardiyaatama.AddNewEvent(btn, tbeOnClick, 'PersonelSec');
}


void PersonelleriYukle
var
  url, response, kalan, kisi, adSoyad, email, departman, arama: String;
  index, ayir1, ayir2, bitis: Integer;
{
  try
    arama = edtPersonelAra.Text;

    scrollPersonel.Visible = False;
    personelListeNo = personelListeNo + 1;

    scrollPersonel = vardiyaatama.AddNewVertScrollBox(pnlPersonelAlan, 'scrollPersonel' + IntToStr(personelListeNo));
    scrollPersonel.Align = alClient;
    scrollPersonel.Margins.Top = 4;
    scrollPersonel.ShowScrollBars = True;

    url = SUPABASE_URL + '/rpc/list_personel_picker';

    RestClient = TclRest.Create;
    RestClient.BaseURL = url;
    RestClient.Accept = 'application/json';
    RestClient.ContentType = 'application/json';
    RestClient.Method = rmPOST;

    RestClient.AddHeader('apikey', SUPABASE_KEY);
    RestClient.AddHeader('Authorization', 'Bearer ' + SUPABASE_KEY);

    RestClient.Body = '{}';
    RestClient.Execute;

    response = RestClient.Response;
    response = SupabaseTextTemizle(response);

    kalan = response;
    index = 0;

    while (Length(kalan) > 0)
    {
      bitis = Pos(';;', kalan);

      if (bitis > 0)
      {
        kisi = Copy(kalan, 1, bitis - 1);
        kalan = Copy(kalan, bitis + 2, Length(kalan));
      }
      else
      {
        kisi = kalan;
        kalan = '';
      }

      ayir1 = Pos('|', kisi);

      if (ayir1 > 0)
      {
        adSoyad = Copy(kisi, 1, ayir1 - 1);
        kisi = Copy(kisi, ayir1 + 1, Length(kisi));

        ayir2 = Pos('|', kisi);

        if (ayir2 > 0)
        {
          email = Copy(kisi, 1, ayir2 - 1);
          departman = Copy(kisi, ayir2 + 1, Length(kisi));

          if (arama == '')
          {
            PersonelButonuOlustur(index, adSoyad, email, departman);
            index = index + 1;
          }
          else
          {
            if (Pos(arama, adSoyad) > 0)
            {
              PersonelButonuOlustur(index, adSoyad, email, departman);
              index = index + 1;
            }
          }
        }
      }
    }

  except
    ShowMessage('Personel listesi alınamadı: ' + LastExceptionMessage);
  }
}


void VardiyaSatiriOlustur(index: Integer; shiftId: String; adSoyad: String; vardiya: String; basSaat: String; bitSaat: String)
var
  pnlSatir: TclProPanel;
  lblBilgi: TclProLabel;
  btnDuzenle, btnSil: TclProButton;
  data: String;
{
  data = shiftId + '|' + adSoyad + '|' + vardiya + '|' + basSaat + '|' + bitSaat;

  pnlSatir = vardiyaatama.AddNewProPanel(scrollVardiyalar, 'pnlShift' + IntToStr(vardiyaListeNo) + '_' + IntToStr(index));
  pnlSatir.Align = alTop;
  pnlSatir.Height = 72;
  pnlSatir.Margins.Top = 6;
  pnlSatir.Margins.Left = 8;
  pnlSatir.Margins.Right = 8;
  pnlSatir.clProSettings.BackgroundColor = clAlphaColor.clHexToColor('#FFFFFF');
  pnlSatir.clProSettings.BorderColor = clAlphaColor.clHexToColor('#E2E8F0');
  pnlSatir.clProSettings.BorderWidth = 1;
  pnlSatir.clProSettings.IsRound = True;
  pnlSatir.clProSettings.RoundHeight = 8;
  pnlSatir.clProSettings.RoundWidth = 8;
  pnlSatir.SetclProSettings(pnlSatir.clProSettings);

  lblBilgi = vardiyaatama.AddNewProLabel(pnlSatir, 'lblShift' + IntToStr(vardiyaListeNo) + '_' + IntToStr(index), adSoyad + ' | ' + vardiya + ' | ' + basSaat + ' - ' + bitSaat);
  lblBilgi.Align = alTop;
  lblBilgi.Height = 32;
  lblBilgi.Margins.Left = 12;
  lblBilgi.Margins.Right = 12;
  lblBilgi.clProSettings.FontSize = 12;
  lblBilgi.clProSettings.FontVertAlign = palCenter;
  lblBilgi.clProSettings.TextSettings.WordWrap = True;
  lblBilgi.SetclProSettings(lblBilgi.clProSettings);

  if (shiftId <> 'bos')
  {
    btnSil = vardiyaatama.AddNewProButton(pnlSatir, 'btnSil' + IntToStr(vardiyaListeNo) + '_' + IntToStr(index), 'Sil');
    btnSil.Align = alRight;
    btnSil.Width = 70;
    btnSil.Margins.Top = 7;
    btnSil.Margins.Bottom = 7;
    btnSil.Margins.Right = 6;
    btnSil.TagString = shiftId;
    btnSil.clProSettings.BackgroundColor = clAlphaColor.clHexToColor('#FEE2E2');
    btnSil.clProSettings.FontColor = clAlphaColor.clHexToColor('#DC2626');
    btnSil.clProSettings.BorderWidth = 0;
    btnSil.clProSettings.IsRound = True;
    btnSil.clProSettings.RoundHeight = 8;
    btnSil.clProSettings.RoundWidth = 8;
    btnSil.SetclProSettings(btnSil.clProSettings);
    vardiyaatama.AddNewEvent(btnSil, tbeOnClick, 'VardiyaSil');

    btnDuzenle = vardiyaatama.AddNewProButton(pnlSatir, 'btnDuzenle' + IntToStr(vardiyaListeNo) + '_' + IntToStr(index), 'Düzenle');
    btnDuzenle.Align = alRight;
    btnDuzenle.Width = 90;
    btnDuzenle.Margins.Top = 7;
    btnDuzenle.Margins.Bottom = 7;
    btnDuzenle.Margins.Right = 6;
    btnDuzenle.TagString = data;
    btnDuzenle.clProSettings.BackgroundColor = clAlphaColor.clHexToColor('#DBEAFE');
    btnDuzenle.clProSettings.FontColor = clAlphaColor.clHexToColor('#1E3A8A');
    btnDuzenle.clProSettings.BorderWidth = 0;
    btnDuzenle.clProSettings.IsRound = True;
    btnDuzenle.clProSettings.RoundHeight = 8;
    btnDuzenle.clProSettings.RoundWidth = 8;
    btnDuzenle.SetclProSettings(btnDuzenle.clProSettings);
    vardiyaatama.AddNewEvent(btnDuzenle, tbeOnClick, 'VardiyaDuzenle');
  }
}


void ListeyiYukle
var
  url, body, response, kalan, satir: String;
  shiftId, adSoyad, vardiya, basSaat, bitSaat: String;
  p1, p2, p3, p4, bitis, index: Integer;
{
  try
    if (seciliTarih == '')
    {
      lblListeBaslik.Text = 'Önce gün seçiniz.';
      lblListeBaslik.SetclProSettings(lblListeBaslik.clProSettings);
    }
    else
    {
      if (scrollVardiyalar <> nil)
      {
        scrollVardiyalar.Visible = False;
      }

      vardiyaListeNo = vardiyaListeNo + 1;

      scrollVardiyalar = vardiyaatama.AddNewVertScrollBox(pnlListeAlan, 'scrollVardiyalar' + IntToStr(vardiyaListeNo));
      scrollVardiyalar.Align = alClient;
      scrollVardiyalar.ShowScrollBars = True;

      lblListeBaslik.Text = seciliGunAdi + ' | ' + seciliTarih;
      lblListeBaslik.SetclProSettings(lblListeBaslik.clProSettings);

      url = SUPABASE_URL + '/rpc/list_shifts_manage_by_date';
      body = '{"p_shift_date":"' + seciliTarih + '"}';

      RestClient = TclRest.Create;
      RestClient.BaseURL = url;
      RestClient.Accept = 'application/json';
      RestClient.ContentType = 'application/json';
      RestClient.Method = rmPOST;

      RestClient.AddHeader('apikey', SUPABASE_KEY);
      RestClient.AddHeader('Authorization', 'Bearer ' + SUPABASE_KEY);

      RestClient.Body = body;
      RestClient.Execute;

      response = RestClient.Response;
      response = SupabaseTextTemizle(response);

      if (response == '')
      {
        VardiyaSatiriOlustur(0, 'bos', 'Bu gün için atanmış vardiya yok.', '-', '-', '-');
      }
      else if (response == 'null')
      {
        VardiyaSatiriOlustur(0, 'bos', 'Bu gün için atanmış vardiya yok.', '-', '-', '-');
      }
      else if (response == '[]')
      {
        VardiyaSatiriOlustur(0, 'bos', 'Bu gün için atanmış vardiya yok.', '-', '-', '-');
      }
      else
      {
        kalan = response;
        index = 0;

        while (Length(kalan) > 0)
        {
          bitis = Pos(';;', kalan);

          if (bitis > 0)
          {
            satir = Copy(kalan, 1, bitis - 1);
            kalan = Copy(kalan, bitis + 2, Length(kalan));
          }
          else
          {
            satir = kalan;
            kalan = '';
          }

          p1 = Pos('|', satir);

          if (p1 > 0)
          {
            shiftId = Copy(satir, 1, p1 - 1);
            satir = Copy(satir, p1 + 1, Length(satir));

            p2 = Pos('|', satir);

            if (p2 > 0)
            {
              adSoyad = Copy(satir, 1, p2 - 1);
              satir = Copy(satir, p2 + 1, Length(satir));

              p3 = Pos('|', satir);

              if (p3 > 0)
              {
                vardiya = Copy(satir, 1, p3 - 1);
                satir = Copy(satir, p3 + 1, Length(satir));

                p4 = Pos('|', satir);

                if (p4 > 0)
                {
                  basSaat = Copy(satir, 1, p4 - 1);
                  bitSaat = Copy(satir, p4 + 1, Length(satir));

                  VardiyaSatiriOlustur(index, shiftId, adSoyad, vardiya, basSaat, bitSaat);
                  index = index + 1;
                }
              }
            }
          }
        }

        if (index == 0)
        {
          VardiyaSatiriOlustur(0, 'bos', 'Liste formatı okunamadı: ' + response, '-', '-', '-');
        }
      }
    }

  except
    ShowMessage('Vardiya listesi alınamadı: ' + LastExceptionMessage);
  }
}


void TarihSec(offsetGun: Integer; aktifBtn: TclProButton)
{
  GunButonlariniSifirla;
  SetButtonActive(aktifBtn);

  seciliTarih = FormatDateTime('yyyy-mm-dd', Now + offsetGun);
  seciliGunAdi = aktifBtn.Text;

  ListeyiYukle;
}



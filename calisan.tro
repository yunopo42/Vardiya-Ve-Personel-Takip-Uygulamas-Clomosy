var
  calisanAna: TCLForm;

  RestClient: TclRest;
  SUPABASE_URL: String;
  SUPABASE_KEY: String;
  EMPLOYEE_TOKEN: String;
  CURRENT_USER_NAME: String;
  CURRENT_USER_ID: String;
  haftalikPlanSayac: Integer;
  molaAktif: Boolean;

  pnlTopBar, pnlWelcome, pnlAktifVardiya, pnlDurumKart, pnlIzinDurum, pnlMolaDurum, pnlPinKart, pnlHizliIslemler, pnlBottomNav: TclProPanel;
  imgLogoTop, imgAvatarTop: TclProImage;
  lblBrand, lblHosGeldin, lblTarih: TclProLabel;
  lblVardiyaBaslik, lblVardiyaSaat, lblVardiyaBolum: TclProLabel;
  lblDurumBaslik, lblDurumMetin: TclProLabel;
  lblIzinDurumBaslik, lblIzinDurumMetin: TclProLabel;
  lblMolaDurumBaslik, lblMolaDurumMetin: TclProLabel;
  lblPinBaslik, lblPinKod, lblPinAciklama: TclProLabel;
  lblHizliIslemBaslik, lblPlanBaslik: TclProLabel;

  btnPinYenile, btnMola, btnIzin, btnAnaSayfa, btnProfil: TclProButton;
  vertScrollBox: TClVertScrollBox;


void SupabaseAyarla
{
  SUPABASE_URL = ''; // Supabase URL removed for GitHub publishing.
  SUPABASE_KEY = ''; // Supabase anon key removed for GitHub publishing.
}


function ParcaAl(metin: String; ayirac: String; index: Integer): String;
var
  i, p: Integer;
  kalan, parca: String;
{
  kalan = metin;
  parca = '';

  for i = 1 to index
  {
    p = Pos(ayirac, kalan);

    if (p > 0)
    {
      parca = Copy(kalan, 1, p - 1);
      kalan = Copy(kalan, p + Length(ayirac), Length(kalan));
    }
    else
    {
      parca = kalan;
      kalan = '';
    }
  }

  Result = parca;
}


function SupabaseTextTemizle(metin: String): String;
var
  sonuc: String;
{
  sonuc = metin;

  if (sonuc == '""')
  {
    Result = '';
    exit;
  }

  if (Length(sonuc) > 0)
  {
    if (Copy(sonuc, 1, 1) == '"')
      sonuc = Copy(sonuc, 2, Length(sonuc));
  }

  if (Length(sonuc) > 0)
  {
    if (Copy(sonuc, Length(sonuc), 1) == '"')
      sonuc = Copy(sonuc, 1, Length(sonuc) - 1);
  }

  Result = sonuc;
}


function GetProfileField(fieldName: String): String;
var
  url, body, response: String;
{
  try
    url = SUPABASE_URL + '/rpc/get_profile_field';
    body = '{"p_field":"' + fieldName + '"}';

    RestClient = TclRest.Create;
    RestClient.BaseURL = url;
    RestClient.Accept = 'application/json';
    RestClient.ContentType = 'application/json';
    RestClient.Method = rmPOST;
    RestClient.AddHeader('apikey', SUPABASE_KEY);
    RestClient.AddHeader('Authorization', 'Bearer ' + SUPABASE_KEY);
    RestClient.Body = body;
    RestClient.Execute;

    response = RestClient.Response;
    response = SupabaseTextTemizle(response);
    Result = response;

  except
    Result = '';
  }
}


void ButtonMolaPasif
{
  btnMola.Text = 'Mola Başlat';
  btnMola.clProSettings.FontColor       = clAlphaColor.clHexToColor('#D97706');
  btnMola.clProSettings.BackgroundColor = clAlphaColor.clHexToColor('#FFFFFF');
  btnMola.clProSettings.BorderColor     = clAlphaColor.clHexToColor('#FDE68A');
  btnMola.SetclProSettings(btnMola.clProSettings);
}


void ButtonMolaAktif
{
  btnMola.Text = 'Mola Bitir';
  btnMola.clProSettings.FontColor       = clAlphaColor.clHexToColor('#FFFFFF');
  btnMola.clProSettings.BackgroundColor = clAlphaColor.clHexToColor('#DC2626');
  btnMola.clProSettings.BorderColor     = clAlphaColor.clHexToColor('#DC2626');
  btnMola.SetclProSettings(btnMola.clProSettings);
}


void CalisanBilgileriYukle
{
  CURRENT_USER_NAME = GetProfileField('full_name');
  CURRENT_USER_ID = GetProfileField('id');
  EMPLOYEE_TOKEN = GetProfileField('qr_token');

  if (CURRENT_USER_NAME <> '')
    lblHosGeldin.Text = 'İyi çalışmalar, ' + CURRENT_USER_NAME
  else
    lblHosGeldin.Text = 'İyi çalışmalar,';

  lblHosGeldin.SetclProSettings(lblHosGeldin.clProSettings);

  if (CURRENT_USER_ID == '-')
    CURRENT_USER_ID = '';

  if (CURRENT_USER_ID == 'null')
    CURRENT_USER_ID = '';

  if (CURRENT_USER_ID == '')
    ShowMessage('Giriş yapan kullanıcının ID bilgisi alınamadı.');
}


void BugunkuVardiyaYukle
var
  url, body, response: String;
  saat, vardiyaTipi, bolum: String;
{
  if (CURRENT_USER_ID == '')
  {
    lblVardiyaSaat.Text = 'Vardiya Yok';
    lblVardiyaBolum.Text = 'Çalışan ID bilgisi alınamadı';
    exit;
  }

  url  = SUPABASE_URL + '/rpc/get_employee_today_shift_by_user';
  body = '{"p_user_id":' + CURRENT_USER_ID + '}';

  try
    RestClient = TclRest.Create;
    RestClient.BaseURL = url;
    RestClient.Accept = 'application/json';
    RestClient.ContentType = 'application/json';
    RestClient.Method = rmPOST;
    RestClient.AddHeader('apikey', SUPABASE_KEY);
    RestClient.AddHeader('Authorization', 'Bearer ' + SUPABASE_KEY);
    RestClient.Body = body;
    RestClient.Execute;

    response = SupabaseTextTemizle(RestClient.Response);

    if (response == '')
    {
      lblVardiyaSaat.Text = 'Vardiya Yok';
      lblVardiyaBolum.Text = 'Bugün için atanmış vardiya bulunmuyor';
      exit;
    }

    if (response == 'null')
    {
      lblVardiyaSaat.Text = 'Vardiya Yok';
      lblVardiyaBolum.Text = 'Bugün için atanmış vardiya bulunmuyor';
      exit;
    }

    saat = ParcaAl(response, '|', 1);
    vardiyaTipi = ParcaAl(response, '|', 2);
    bolum = ParcaAl(response, '|', 3);

    lblVardiyaSaat.Text = saat;
    lblVardiyaBolum.Text = bolum + '  •  ' + vardiyaTipi;
  except
    ShowMessage('Bugünkü vardiya yüklenemedi: ' + LastExceptionMessage);
  }
}


void GirisCikisDurumuYukle
var
  url, body, response: String;
  durum, giris, cikis, mesaj, mola: String;
{
  if (CURRENT_USER_ID == '')
  {
    lblDurumMetin.Text = 'Kullanıcı bilgisi alınamadı.';
    lblDurumMetin.SetclProSettings(lblDurumMetin.clProSettings);
    exit;
  }

  url = SUPABASE_URL + '/rpc/get_employee_attendance_status_by_user';
  body = '{"p_user_id":' + CURRENT_USER_ID + '}';

  try
    RestClient = TclRest.Create;
    RestClient.BaseURL = url;
    RestClient.Accept = 'application/json';
    RestClient.ContentType = 'application/json';
    RestClient.Method = rmPOST;
    RestClient.AddHeader('apikey', SUPABASE_KEY);
    RestClient.AddHeader('Authorization', 'Bearer ' + SUPABASE_KEY);
    RestClient.Body = body;
    RestClient.Execute;

    response = SupabaseTextTemizle(RestClient.Response);

    durum = ParcaAl(response, '|', 1);
    giris = ParcaAl(response, '|', 2);
    cikis = ParcaAl(response, '|', 3);
    mesaj = ParcaAl(response, '|', 4);
    mola = ParcaAl(response, '|', 5);

    if (durum == '0')
    {
      lblDurumMetin.Text = mesaj + ' | Mola: ' + mola + ' dk';
      lblDurumMetin.clProSettings.FontColor = clAlphaColor.clHexToColor('#64748B');
    }
    else if (durum == '1')
    {
      lblDurumMetin.Text = 'Giriş: ' + giris + ' | Çıkış: - | ' + mesaj + ' | Mola: ' + mola + ' dk';
      lblDurumMetin.clProSettings.FontColor = clAlphaColor.clHexToColor('#16A34A');
    }
    else
    {
      lblDurumMetin.Text = 'Giriş: ' + giris + ' | Çıkış: ' + cikis + ' | ' + mesaj + ' | Mola: ' + mola + ' dk';
      lblDurumMetin.clProSettings.FontColor = clAlphaColor.clHexToColor('#1E3A8A');
    }

    lblDurumMetin.SetclProSettings(lblDurumMetin.clProSettings);

  except
    lblDurumMetin.Text = 'Giriş/çıkış durumu alınamadı.';
    lblDurumMetin.SetclProSettings(lblDurumMetin.clProSettings);
  }
}


void IzinDurumuYukle
var
  url, body, response: String;
  durum, tur, tarih, neden: String;
{
  if (CURRENT_USER_ID == '')
  {
    lblIzinDurumMetin.Text = 'Kullanıcı bilgisi alınamadı.';
    lblIzinDurumMetin.SetclProSettings(lblIzinDurumMetin.clProSettings);
    exit;
  }

  url = SUPABASE_URL + '/rpc/get_employee_leave_status_by_user';
  body = '{"p_user_id":' + CURRENT_USER_ID + '}';

  try
    RestClient = TclRest.Create;
    RestClient.BaseURL = url;
    RestClient.Accept = 'application/json';
    RestClient.ContentType = 'application/json';
    RestClient.Method = rmPOST;
    RestClient.AddHeader('apikey', SUPABASE_KEY);
    RestClient.AddHeader('Authorization', 'Bearer ' + SUPABASE_KEY);
    RestClient.Body = body;
    RestClient.Execute;

    response = SupabaseTextTemizle(RestClient.Response);

    if (response == '')
    {
      lblIzinDurumMetin.Text = 'Aktif veya bekleyen izin talebiniz bulunmuyor.';
      lblIzinDurumMetin.clProSettings.FontColor = clAlphaColor.clHexToColor('#64748B');
      lblIzinDurumMetin.SetclProSettings(lblIzinDurumMetin.clProSettings);
      exit;
    }

    if (response == 'null')
    {
      lblIzinDurumMetin.Text = 'Aktif veya bekleyen izin talebiniz bulunmuyor.';
      lblIzinDurumMetin.clProSettings.FontColor = clAlphaColor.clHexToColor('#64748B');
      lblIzinDurumMetin.SetclProSettings(lblIzinDurumMetin.clProSettings);
      exit;
    }

    durum = ParcaAl(response, '|', 1);
    tur   = ParcaAl(response, '|', 2);
    tarih = ParcaAl(response, '|', 3);
    neden = ParcaAl(response, '|', 4);

    if (durum == 'Onaylandı')
    {
      lblIzinDurumMetin.Text = tarih + ' tarih aralığında ' + tur + ' türünden izinlisiniz.';
      lblIzinDurumMetin.clProSettings.FontColor = clAlphaColor.clHexToColor('#16A34A');
    }
    else if (durum == 'Bekliyor')
    {
      lblIzinDurumMetin.Text = tarih + ' tarih aralığındaki ' + tur + ' talebiniz yönetici onayı bekliyor.';
      lblIzinDurumMetin.clProSettings.FontColor = clAlphaColor.clHexToColor('#D97706');
    }
    else if (durum == 'Reddedildi')
    {
      lblIzinDurumMetin.Text = tarih + ' tarih aralığındaki ' + tur + ' talebiniz reddedildi.';
      lblIzinDurumMetin.clProSettings.FontColor = clAlphaColor.clHexToColor('#DC2626');
    }
    else
    {
      lblIzinDurumMetin.Text = response;
      lblIzinDurumMetin.clProSettings.FontColor = clAlphaColor.clHexToColor('#64748B');
    }

    lblIzinDurumMetin.SetclProSettings(lblIzinDurumMetin.clProSettings);

  except
    lblIzinDurumMetin.Text = 'İzin durumu alınamadı.';
    lblIzinDurumMetin.SetclProSettings(lblIzinDurumMetin.clProSettings);
  }
}


void MolaDurumuYukle
var
  url, body, response: String;
  hasShift, shiftTime, usedMin, remainingMin, active, mesaj: String;
{
  if (CURRENT_USER_ID == '')
  {
    lblMolaDurumMetin.Text = 'Kullanıcı bilgisi alınamadı.';
    lblMolaDurumMetin.SetclProSettings(lblMolaDurumMetin.clProSettings);
    exit;
  }

  url = SUPABASE_URL + '/rpc/get_employee_break_status_by_user';
  body = '{"p_user_id":' + CURRENT_USER_ID + '}';

  try
    RestClient = TclRest.Create;
    RestClient.BaseURL = url;
    RestClient.Accept = 'application/json';
    RestClient.ContentType = 'application/json';
    RestClient.Method = rmPOST;
    RestClient.AddHeader('apikey', SUPABASE_KEY);
    RestClient.AddHeader('Authorization', 'Bearer ' + SUPABASE_KEY);
    RestClient.Body = body;
    RestClient.Execute;

    response = SupabaseTextTemizle(RestClient.Response);

    hasShift     = ParcaAl(response, '|', 1);
    shiftTime    = ParcaAl(response, '|', 2);
    usedMin      = ParcaAl(response, '|', 3);
    remainingMin = ParcaAl(response, '|', 4);
    active       = ParcaAl(response, '|', 5);
    mesaj        = ParcaAl(response, '|', 6);

    if (hasShift == '0')
    {
      lblMolaDurumMetin.Text = mesaj;
      molaAktif = False;
      ButtonMolaPasif;
    }
    else
    {
      lblMolaDurumMetin.Text = 'Mesai: ' + shiftTime + ' | Kullanılan: ' + usedMin + ' dk | Kalan: ' + remainingMin + ' dk';

      if (active == '0')
      {
        molaAktif = False;
        ButtonMolaPasif;
      }
      else
      {
        molaAktif = True;
        ButtonMolaAktif;
      }
    }

    lblMolaDurumMetin.SetclProSettings(lblMolaDurumMetin.clProSettings);

  except
    lblMolaDurumMetin.Text = 'Mola bilgisi alınamadı.';
    lblMolaDurumMetin.SetclProSettings(lblMolaDurumMetin.clProSettings);
  }
}


void CalisanPinYukle
var
  url, body, response: String;
{
  if (CURRENT_USER_ID == '')
  {
    lblPinKod.Text = '------';
    lblPinAciklama.Text = 'Kullanıcı ID bilgisi alınamadı.';
    exit;
  }

  url = SUPABASE_URL + '/rpc/generate_employee_pin';
  body = '{"p_user_id":' + CURRENT_USER_ID + '}';

  try
    RestClient = TclRest.Create;
    RestClient.BaseURL = url;
    RestClient.Accept = 'application/json';
    RestClient.ContentType = 'application/json';
    RestClient.Method = rmPOST;
    RestClient.AddHeader('apikey', SUPABASE_KEY);
    RestClient.AddHeader('Authorization', 'Bearer ' + SUPABASE_KEY);
    RestClient.Body = body;
    RestClient.Execute;

    response = SupabaseTextTemizle(RestClient.Response);

    if (response == '')
      lblPinKod.Text = '------'
    else
      lblPinKod.Text = response;

    lblPinAciklama.Text = 'Bu PIN 15 dakika geçerlidir. Giriş/çıkış için yöneticinize söyleyin.';

    lblPinKod.SetclProSettings(lblPinKod.clProSettings);
    lblPinAciklama.SetclProSettings(lblPinAciklama.clProSettings);

  except
    lblPinKod.Text = 'HATA';
    lblPinAciklama.Text = 'PIN oluşturulamadı.';
  }
}


void SendMolaRequest(isBaslangic: Boolean)
var
  url, body, tip, response: String;
{
  if (CURRENT_USER_ID == '')
  {
    ShowMessage('Kullanıcı bilgisi alınamadı.');
    exit;
  }

  url = SUPABASE_URL + '/rpc/handle_break_limited_by_user';

  if (isBaslangic)
    tip = 'start'
  else
    tip = 'end';

  body = '{"p_user_id":' + CURRENT_USER_ID + ','
       + '"p_action":"' + tip + '"}';

  try
    RestClient = TclRest.Create;
    RestClient.BaseURL = url;
    RestClient.Accept = 'application/json';
    RestClient.ContentType = 'application/json';
    RestClient.Method = rmPOST;
    RestClient.AddHeader('apikey', SUPABASE_KEY);
    RestClient.AddHeader('Authorization', 'Bearer ' + SUPABASE_KEY);
    RestClient.Body = body;
    RestClient.Execute;

    response = SupabaseTextTemizle(RestClient.Response);
    ShowMessage(response);

    MolaDurumuYukle;
    GirisCikisDurumuYukle;

  except
    ShowMessage('Mola işlemi yapılamadı: ' + LastExceptionMessage);
  }
}


void GoToMola
{
  if (molaAktif == True)
    SendMolaRequest(False)
  else
    SendMolaRequest(True);
}


void GoToIzin
{
  calisanAna.clHide;
  Clomosy.RunUnit('izintalebi');
}


void GoToProfil
{
  calisanAna.clHide;
  Clomosy.RunUnit('profil');
}


function PlanKartOlustur(parent: TclVertScrollBox; ad: String; gun: String; saat: String; durum: String): TclProPanel;
var
  pnlKart: TclProPanel;
  lblGun, lblSaat, lblDurum: TclProLabel;
{
  pnlKart = calisanAna.AddNewProPanel(parent, ad + '_kart');
  pnlKart.Align = alTop;
  pnlKart.Height = 60;
  pnlKart.Margins.Top = 10;
  pnlKart.Margins.Left = 16;
  pnlKart.Margins.Right = 16;
  pnlKart.clProSettings.BackgroundColor = clAlphaColor.clHexToColor('#FFFFFF');
  pnlKart.clProSettings.IsRound = True;
  pnlKart.clProSettings.RoundHeight = 10;
  pnlKart.clProSettings.RoundWidth = 10;
  pnlKart.clProSettings.BorderColor = clAlphaColor.clHexToColor('#E2E8F0');
  pnlKart.clProSettings.BorderWidth = 1;
  pnlKart.SetclProSettings(pnlKart.clProSettings);

  lblGun = calisanAna.AddNewProLabel(pnlKart, ad + '_gun', gun);
  lblGun.Align = alLeft;
  lblGun.Width = 95;
  lblGun.Margins.Left = 15;
  lblGun.clProSettings.FontColor = clAlphaColor.clHexToColor('#0F172A');
  lblGun.clProSettings.FontSize = 12;
  lblGun.clProSettings.TextSettings.Font.Style = [fsBold];
  lblGun.clProSettings.FontVertAlign = palCenter;
  lblGun.SetclProSettings(lblGun.clProSettings);

  lblSaat = calisanAna.AddNewProLabel(pnlKart, ad + '_saat', saat);
  lblSaat.Align = alClient;
  lblSaat.clProSettings.FontColor = clAlphaColor.clHexToColor('#64748B');
  lblSaat.clProSettings.FontSize = 12;
  lblSaat.clProSettings.FontVertAlign = palCenter;
  lblSaat.SetclProSettings(lblSaat.clProSettings);

  lblDurum = calisanAna.AddNewProLabel(pnlKart, ad + '_durum', durum);
  lblDurum.Align = alRight;
  lblDurum.Width = 85;
  lblDurum.Margins.Right = 15;
  lblDurum.clProSettings.FontSize = 12;
  lblDurum.clProSettings.TextSettings.Font.Style = [fsBold];
  lblDurum.clProSettings.FontVertAlign = palCenter;
  lblDurum.clProSettings.FontHorzAlign = palTrailing;

  if (durum == 'İzinli')
    lblDurum.clProSettings.FontColor = clAlphaColor.clHexToColor('#EF4444')
  else if (durum == 'Vardiya Yok')
    lblDurum.clProSettings.FontColor = clAlphaColor.clHexToColor('#64748B')
  else
    lblDurum.clProSettings.FontColor = clAlphaColor.clHexToColor('#10B981');

  lblDurum.SetclProSettings(lblDurum.clProSettings);
  Result = pnlKart;
}


void HaftalikVardiyalariYukle
var
  url, body, response: String;
  kayit, gun, saat, durum, bolum: String;
  i: Integer;
{
  if (CURRENT_USER_ID == '')
  {
    PlanKartOlustur(vertScrollBox, 'bos_plan_token', 'Bu hafta', '-', 'Vardiya Yok');
    exit;
  }

  url = SUPABASE_URL + '/rpc/get_employee_weekly_shifts_by_user';
  body = '{"p_user_id":' + CURRENT_USER_ID + '}';

  try
    RestClient = TclRest.Create;
    RestClient.BaseURL = url;
    RestClient.Accept = 'application/json';
    RestClient.ContentType = 'application/json';
    RestClient.Method = rmPOST;
    RestClient.AddHeader('apikey', SUPABASE_KEY);
    RestClient.AddHeader('Authorization', 'Bearer ' + SUPABASE_KEY);
    RestClient.Body = body;
    RestClient.Execute;

    response = SupabaseTextTemizle(RestClient.Response);

    if (response == '')
    {
      PlanKartOlustur(vertScrollBox, 'bos_plan', 'Bu hafta', '-', 'Vardiya Yok');
      exit;
    }

    if (response == 'null')
    {
      PlanKartOlustur(vertScrollBox, 'bos_plan_null', 'Bu hafta', '-', 'Vardiya Yok');
      exit;
    }

    i = 1;
    kayit = ParcaAl(response, ';', i);

    while (kayit <> '')
    {
      gun = ParcaAl(kayit, '|', 1);
      saat = ParcaAl(kayit, '|', 2);
      durum = ParcaAl(kayit, '|', 3);
      bolum = ParcaAl(kayit, '|', 4);

      haftalikPlanSayac = haftalikPlanSayac + 1;

      if (bolum == '-')
        PlanKartOlustur(vertScrollBox, 'db_plan_' + IntToStr(haftalikPlanSayac), gun, saat, durum)
      else
        PlanKartOlustur(vertScrollBox, 'db_plan_' + IntToStr(haftalikPlanSayac), gun, saat + ' / ' + bolum, durum);

      i = i + 1;
      kayit = ParcaAl(response, ';', i);
    }

  except
    ShowMessage('Haftalık vardiyalar yüklenemedi: ' + LastExceptionMessage);
  }
}


void BtnPress
var
  btn: TClProButton;
{
  btn = TClProButton(calisanAna.clSender);
  btn.Position.Y = btn.Position.Y + 2;
}


void BtnRelease
var
  btn: TClProButton;
{
  btn = TClProButton(calisanAna.clSender);
  btn.Position.Y = btn.Position.Y - 2;
}



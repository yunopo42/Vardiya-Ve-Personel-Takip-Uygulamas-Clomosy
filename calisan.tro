{
  lbl.clProSettings.FontColor = clAlphaColor.clHexToColor(renk);
  lbl.clProSettings.FontSize = 14;
  lbl.clProSettings.TextSettings.Font.Style = [fsBold];
  lbl.SetclProSettings(lbl.clProSettings);
}


{
  SupabaseAyarla;

  EMPLOYEE_TOKEN = '';
  CURRENT_USER_NAME = '';
  CURRENT_USER_ID = '';
  haftalikPlanSayac = 0;
  molaAktif = False;

  calisanAna = TCLForm.Create(Self);

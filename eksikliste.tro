  lblAciklama.clProSettings.TextSettings.WordWrap = True;
  lblAciklama.SetclProSettings(lblAciklama.clProSettings);
}


void ListeyiDoldur
var
  url, response: String;
  kalan, kayit: String;
  idText, adSoyad, email, departman, pozisyon: String;
  bitis: Integer;
{
  listeNo = 0;

  try
    url = SUPABASE_URL + '/rpc/list_missing_users_today';

    RestClient = TclRest.Create;
    RestClient.BaseURL = url;
    RestClient.Accept = 'application/json';
    RestClient.ContentType = 'application/json';
    RestClient.Method = rmPOST;

    RestClient.AddHeader('apikey', SUPABASE_KEY);
    RestClient.AddHeader('Authorization', 'Bearer ' + SUPABASE_KEY);

    RestClient.Body = '{}';
    RestClient.Execute;

    response = RestClient.Response;
    response = SupabaseTextTemizle(response);

    if (response == '')
    {
      BilgiKartOlustur(
        'Eksik personel yok',
        'Bugün giriş yapmayan ve izinli olmayan personel bulunmuyor.'
      );
      exit;
    }

    if (response == 'null')
    {
      BilgiKartOlustur(
        'Eksik personel yok',
        'Bugün giriş yapmayan ve izinli olmayan personel bulunmuyor.'
      );
      exit;
    }

    if (response == '[]')
    {
      BilgiKartOlustur(
        'Eksik personel yok',
        'Bugün giriş yapmayan ve izinli olmayan personel bulunmuyor.'
      );
      exit;
    }

    if (Copy(response, 1, 1) == '{')
    {
      BilgiKartOlustur(
        'Supabase hatası',
        response
      );
      exit;
    }

    kalan = response;

    while (Length(kalan) > 0)
    {
      bitis = Pos(';;', kalan);

      if (bitis > 0)
      {
        kayit = Copy(kalan, 1, bitis - 1);
        kalan = Copy(kalan, bitis + 2, Length(kalan));
      }
      else
      {
        kayit = kalan;
        kalan = '';
      }

      idText   = ParcaAl(kayit, '|', 1);
      adSoyad  = ParcaAl(kayit, '|', 2);
      email    = ParcaAl(kayit, '|', 3);
      departman = ParcaAl(kayit, '|', 4);
      pozisyon = ParcaAl(kayit, '|', 5);

      EksikKartOlustur(
        idText,
        adSoyad,
        email,
        departman,
        pozisyon
      );
    }

  except
    BilgiKartOlustur(
      'Liste alınamadı',
      'Eksik personel listesi yüklenirken hata oluştu: ' + LastExceptionMessage
    );
  }
}


void BtnPress
var
  btn: TClProButton;
{
  btn = TClProButton(eksikliste.clSender);
  btn.Position.Y = btn.Position.Y + 2;
}


void BtnRelease
var
  btn: TClProButton;
{
  btn = TClProButton(eksikliste.clSender);
  btn.Position.Y = btn.Position.Y - 2;
}


{
  SupabaseAyarla;

  eksikliste = TCLForm.Create(nil);
  eksikliste.SetFormColor('#F8FAFC', '', clGNone);

  pnlTop = eksikliste.AddNewProPanel(eksikliste, 'pnlTop');
  pnlTop.Align = alTop;
  pnlTop.Height = 70;
  pnlTop.clProSettings.BackgroundColor = clAlphaColor.clHexToColor('#FFFFFF');
  pnlTop.clProSettings.BorderColor = clAlphaColor.clHexToColor('#E2E8F0');
  pnlTop.clProSettings.BorderWidth = 1;
  pnlTop.SetclProSettings(pnlTop.clProSettings);

  btnGeri = eksikliste.AddNewProButton(pnlTop, 'btnGeri', 'Geri');
  btnGeri.Align = alLeft;
  btnGeri.Width = 90;
  btnGeri.Margins.Left = 10;
  btnGeri.Margins.Top = 12;
  btnGeri.Margins.Bottom = 12;
  btnGeri.clProSettings.FontColor = clAlphaColor.clHexToColor('#FFFFFF');
  btnGeri.clProSettings.BackgroundColor = clAlphaColor.clHexToColor('#0D1B3E');
  btnGeri.clProSettings.IsRound = True;
  btnGeri.clProSettings.RoundHeight = 8;
  btnGeri.clProSettings.RoundWidth = 8;
  btnGeri.SetclProSettings(btnGeri.clProSettings);
  eksikliste.AddNewEvent(btnGeri, tbeOnClick, 'GoBack');
  eksikliste.AddNewEvent(btnGeri, tbeOnMouseDown, 'BtnPress');
  eksikliste.AddNewEvent(btnGeri, tbeOnMouseUp, 'BtnRelease');

  lblBaslik = eksikliste.AddNewProLabel(pnlTop, 'lblBaslik', 'Eksik Personel Listesi');
  lblBaslik.Align = alClient;
  lblBaslik.clProSettings.FontSize = 17;
  lblBaslik.clProSettings.FontColor = clAlphaColor.clHexToColor('#0F172A');
  lblBaslik.clProSettings.TextSettings.Font.Style = [fsBold];
  lblBaslik.clProSettings.FontVertAlign = palCenter;
  lblBaslik.clProSettings.FontHorzAlign = palCenter;
  lblBaslik.SetclProSettings(lblBaslik.clProSettings);

  btnYenile = eksikliste.AddNewProButton(pnlTop, 'btnYenile', 'Yenile');
  btnYenile.Align = alRight;
  btnYenile.Width = 90;
  btnYenile.Margins.Right = 10;
  btnYenile.Margins.Top = 12;
  btnYenile.Margins.Bottom = 12;
  btnYenile.clProSettings.FontColor = clAlphaColor.clHexToColor('#1E3A8A');
  btnYenile.clProSettings.BackgroundColor = clAlphaColor.clHexToColor('#DBEAFE');
  btnYenile.clProSettings.IsRound = True;
  btnYenile.clProSettings.RoundHeight = 8;
  btnYenile.clProSettings.RoundWidth = 8;
  btnYenile.SetclProSettings(btnYenile.clProSettings);
  eksikliste.AddNewEvent(btnYenile, tbeOnClick, 'SayfayiYenile');
  eksikliste.AddNewEvent(btnYenile, tbeOnMouseDown, 'BtnPress');
  eksikliste.AddNewEvent(btnYenile, tbeOnMouseUp, 'BtnRelease');

  scrollListe = eksikliste.AddNewVertScrollBox(eksikliste, 'scrollListe');
  scrollListe.Align = alClient;
  scrollListe.ShowScrollBars = False;

  ListeyiDoldur;

  eksikliste.AddNewProPanel(scrollListe, 'pnlBottomSpace').Align = alTop;

  eksikliste.Run;
}

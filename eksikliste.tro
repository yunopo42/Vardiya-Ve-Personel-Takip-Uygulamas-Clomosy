  lblAd.Height = 28;
  lblAd.Margins.Left = 18;
  lblAd.Margins.Right = 15;
  lblAd.Margins.Top = 12;
  lblAd.clProSettings.FontColor = clAlphaColor.clHexToColor('#0F172A');
  lblAd.clProSettings.FontSize = 15;
  lblAd.clProSettings.TextSettings.Font.Style = [fsBold];
  lblAd.SetclProSettings(lblAd.clProSettings);

  lblEmail = eksikliste.AddNewProLabel(pnlKart, 'lblEmail_' + IntToStr(listeNo), email);
  lblEmail.Align = alTop;
  lblEmail.Height = 22;
  lblEmail.Margins.Left = 18;
  lblEmail.Margins.Right = 15;
  lblEmail.clProSettings.FontColor = clAlphaColor.clHexToColor('#64748B');
  lblEmail.clProSettings.FontSize = 11;
  lblEmail.SetclProSettings(lblEmail.clProSettings);

  lblDepartman = eksikliste.AddNewProLabel(pnlKart, 'lblDepartman_' + IntToStr(listeNo), departman + ' | ' + pozisyon);
  lblDepartman.Align = alTop;
  lblDepartman.Height = 24;
  lblDepartman.Margins.Left = 18;
  lblDepartman.Margins.Right = 15;
  lblDepartman.Margins.Top = 4;
  lblDepartman.clProSettings.FontColor = clAlphaColor.clHexToColor('#334155');
  lblDepartman.clProSettings.FontSize = 12;
  lblDepartman.SetclProSettings(lblDepartman.clProSettings);

  lblDurum = eksikliste.AddNewProLabel(pnlKart, 'lblDurum_' + IntToStr(listeNo), 'Bugün giriş yapmadı / izinli değil');
  lblDurum.Align = alBottom;
  lblDurum.Height = 25;
  lblDurum.Margins.Left = 18;
  lblDurum.Margins.Right = 15;
  lblDurum.Margins.Bottom = 8;
  lblDurum.clProSettings.FontColor = clAlphaColor.clHexToColor('#EF4444');
  lblDurum.clProSettings.FontSize = 11;
  lblDurum.clProSettings.TextSettings.Font.Style = [fsBold];
